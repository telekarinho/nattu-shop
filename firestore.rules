rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Meta collection — system init + seed tracking
    match /meta/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Users collection — auth + approval
    match /users/{userId} {
      allow read: if request.auth != null
                    && (request.auth.uid == userId || isApproved());
      allow create: if request.auth != null
                      && request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    // Global products catalog — public read for catalog pages
    match /produtos/{productId} {
      allow read: if true;
      allow write: if isAdmin() || isGerente() || isEstoquista();
    }

    // Global customers — public checkout can create
    match /clientes/{clienteId} {
      allow read: if request.auth != null && isApproved();
      allow create: if true;
      allow update, delete: if isAdmin() || isGerente();
    }

    // Global subscriptions — public checkout can create
    match /assinaturas/{subId} {
      allow read: if isAdmin() || canAccessStore(resource.data.loja);
      allow create: if true;
      allow update, delete: if isAdmin() || isGerenteOfStore(resource.data.loja);
    }

    // Global employees (dono-level, no store)
    match /funcionarios/{funcId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Store-scoped data
    match /lojas/{storeId} {
      allow read: if true;
      allow write: if isAdmin();

      // Per-store product activation
      match /produtos_ativos/{productId} {
        allow read: if true;
        allow write: if isAdmin() || isGerenteOfStore(storeId);
      }

      // Per-store stock
      match /estoque/{productId} {
        allow read: if canAccessStore(storeId);
        allow write: if isAdmin() || isGerenteOfStore(storeId) || isEstoquistaOfStore(storeId);
      }

      // Per-store stock movements
      match /movimentacoes/{movId} {
        allow read: if canAccessStore(storeId);
        allow create: if isAdmin() || isGerenteOfStore(storeId) || isEstoquistaOfStore(storeId);
        allow update, delete: if isAdmin();
      }

      // Per-store employees
      match /funcionarios/{funcId} {
        allow read: if isAdmin() || isGerenteOfStore(storeId);
        allow write: if isAdmin() || isGerenteOfStore(storeId);
      }

      // Per-store orders — public checkout can create
      match /pedidos/{pedidoId} {
        allow read: if canAccessStore(storeId);
        allow create: if true;
        allow update: if isAdmin() || isGerenteOfStore(storeId) || isWorkerOfStore(storeId);
        allow delete: if isAdmin();
      }

      // Per-store fiscal notes
      match /notas_fiscais/{nfId} {
        allow read: if isAdmin() || isGerenteOfStore(storeId) || isCaixaOfStore(storeId);
        allow write: if isAdmin() || isGerenteOfStore(storeId) || isCaixaOfStore(storeId);
      }

      // Per-store fiscal configuration
      match /fiscal_config/{docId} {
        allow read: if isAdmin() || isGerenteOfStore(storeId) || isCaixaOfStore(storeId);
        allow write: if isAdmin() || isGerenteOfStore(storeId);
      }

      // Per-store fiscal audit trail
      match /fiscal_audit_logs/{docId} {
        allow read: if isAdmin() || isGerenteOfStore(storeId) || isCaixaOfStore(storeId);
        allow create: if isAdmin() || isGerenteOfStore(storeId) || isCaixaOfStore(storeId);
        allow update, delete: if isAdmin();
      }

      // Per-store cash register
      match /caixa/{sessionId} {
        allow read: if isAdmin() || isGerenteOfStore(storeId) || isCaixaOfStore(storeId);
        allow write: if isAdmin() || isGerenteOfStore(storeId) || isCaixaOfStore(storeId);
      }

      // Per-store financial module
      match /financial_periods/{docId} {
        allow read: if isAdmin() || isGerenteOfStore(storeId) || isCaixaOfStore(storeId);
        allow write: if isAdmin() || isGerenteOfStore(storeId);
      }
      match /fixed_cost_entries/{docId} {
        allow read: if isAdmin() || isGerenteOfStore(storeId) || isCaixaOfStore(storeId);
        allow write: if isAdmin() || isGerenteOfStore(storeId);
      }
      match /variable_cost_entries/{docId} {
        allow read: if isAdmin() || isGerenteOfStore(storeId) || isCaixaOfStore(storeId);
        allow write: if isAdmin() || isGerenteOfStore(storeId);
      }
      match /financial_snapshots/{docId} {
        allow read: if isAdmin() || isGerenteOfStore(storeId) || isCaixaOfStore(storeId);
        allow write: if isAdmin() || isGerenteOfStore(storeId);
      }
      match /health_scores/{docId} {
        allow read: if isAdmin() || isGerenteOfStore(storeId) || isCaixaOfStore(storeId);
        allow write: if isAdmin() || isGerenteOfStore(storeId);
      }
    }

    // Gamification
    match /metas_config/{docId} {
      allow read: if request.auth != null && isApproved();
      allow write: if isAdmin() || isGerente();
    }
    match /metas_pontos/{empId} {
      allow read: if request.auth != null && isApproved();
      allow write: if request.auth != null && isApproved();
    }
    match /metas_provas/{proofId} {
      allow read: if request.auth != null && isApproved();
      allow create: if request.auth != null && isApproved();
      allow update, delete: if isAdmin() || isGerente();
    }
    match /metas_attendance/{recordId} {
      allow read: if request.auth != null && isApproved();
      allow write: if request.auth != null && isApproved();
    }
    match /metas_tasks/{taskId} {
      allow read: if request.auth != null && isApproved();
      allow write: if request.auth != null && isApproved();
    }

    // Affiliates
    match /afiliados/{afiliadoId} {
      allow read: if request.auth != null && isApproved();
      allow write: if isAdmin() || isGerente();
    }
    match /afiliado_sales/{saleId} {
      allow read: if request.auth != null && isApproved();
      allow create: if true;
      allow update, delete: if isAdmin() || isGerente();
    }
    match /afiliado_config/{docId} {
      allow read: if request.auth != null && isApproved();
      allow write: if isAdmin();
    }

    // ============ HELPER FUNCTIONS ============

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return request.auth != null && getUserData().role == 'dono';
    }

    function isGerente() {
      return request.auth != null && getUserData().role == 'gerente';
    }

    function isApproved() {
      return request.auth != null && getUserData().approved == true;
    }

    function isEstoquista() {
      return request.auth != null && getUserData().role == 'estoquista';
    }

    function isGerenteOfStore(storeId) {
      return request.auth != null
        && getUserData().role == 'gerente'
        && getUserData().approved == true
        && getUserData().storeId == storeId;
    }

    function isEstoquistaOfStore(storeId) {
      return request.auth != null
        && getUserData().role == 'estoquista'
        && getUserData().approved == true
        && getUserData().storeId == storeId;
    }

    function isCaixaOfStore(storeId) {
      return request.auth != null
        && getUserData().role == 'caixa'
        && getUserData().approved == true
        && getUserData().storeId == storeId;
    }

    function isWorkerOfStore(storeId) {
      return request.auth != null
        && getUserData().approved == true
        && getUserData().storeId == storeId;
    }

    function canAccessStore(storeId) {
      return request.auth != null
        && (
          isAdmin()
          || (getUserData().approved == true && getUserData().storeId == storeId)
        );
    }
  }
}
